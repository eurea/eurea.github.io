{
  "name": "gbf-calculator",
  "version": "3.1.0",
  "private": true,
  "homepage": "https://eurea.github.io",
  "type": "module",
  "scripts": {
    "start": "vite --open",
    "build": "tsc && vite build",
    "predeploy": "bun run build",
    "deploy": "gh-pages -b master -d build -m \"Deploy new version\"",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "bootstrap": "^4.6.2",
    "query-string": "^9.4.1",
    "react": "^18.3.1",
    "react-bootstrap": "^1.6.8",
    "react-dom": "^18.3.1",
    "react-ga4": "^3.0.1",
    "react-github-corner": "^2.5.0",
    "react-localization": "^2.0.6",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-redux": "^7.1.34",
    "@vitejs/plugin-react": "^5.0.0",
    "gh-pages": "^6.3.0",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-mkcert": "^2.1.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
